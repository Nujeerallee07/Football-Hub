# =============================================
# Football Live Hub - Environment Variables
# =============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ---- API-Football (api-sports.io) ----
# Sign up at: https://www.api-football.com/
# Free tier: 100 requests/day | Pro: unlimited
NEXT_PUBLIC_API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ---- The Odds API ----
# Sign up at: https://the-odds-api.com/
# Free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here
NEXT_PUBLIC_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Football Live Hub

# ---- League IDs (API-Football) ----
# Premier League
NEXT_PUBLIC_PREMIER_LEAGUE_ID=39
# UEFA Champions League
NEXT_PUBLIC_CHAMPIONS_LEAGUE_ID=2
# Current season
NEXT_PUBLIC_CURRENT_SEASON=2024

# ---- Revalidation (seconds) ----
LIVE_DATA_REVALIDATE=60
STANDINGS_REVALIDATE=300
FIXTURES_REVALIDATE=120
